{
  "manifest_version": 3,
  "name": "Navis - AI Chat Minimap",
  "version": "1.0.0",
  "description": "A tiny minimap for AI chat interfaces. Navigate your conversations visually. Works on ChatGPT, Gemini, and Claude.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content/platforms.js", "content/minimap.js", "content/main.js"],
      "css": ["content/minimap.css"],
      "run_at": "document_idle"
    }
  ]
}
